#!/usr/bin/env expect
# Two-process integration tests for bknr-repl replication, driven with `expect`.
#
# Why expect: these scenarios need two live processes (a primary and a standby)
# talking over TCP, because two stores in one image would share the global CLOS
# class indices.  The earlier bash version choreographed them with fixed `sleep`s
# ("connect only AFTER the snapshot") which is timing-fragile.  Here each step
# instead WAITS FOR AN ACTUAL OUTPUT MARKER -- "serving replicas on", "in sync
# (bootstrap", "committed #", "primary disconnected" -- so the ordering is
# deterministic.  A couple of scenarios (B, C) still need a real downtime window
# while the primary is down; that is the library's ~0.5s reconnect backoff, and
# we exploit it by committing into the restarted primary before the standby's
# next reconnect, rather than by sleeping a guessed amount.
#
# Uses the `bknr-repl` binary on PATH; override with BKNR_REPL=/path/to/bknr-repl.
# Build first:  ros build bin/bknr-repl.ros && install -m755 bin/bknr-repl ~/.local/bin/

set BIN  [expr {[info exists env(BKNR_REPL)] ? $env(BKNR_REPL) : "bknr-repl"}]
set BASE [exec mktemp -d]
set timeout 30
log_user 0
set ::PASS 0
set ::FAIL 0

proc ok  {m} { incr ::PASS; puts "  OK:   $m" }
proc bad {m} { incr ::FAIL; puts "  FAIL: $m" }

# Spawn a role on PORT/DIR; returns the spawn id.  Extra CLI flags via ARGS.
proc launch {role port dir args} {
    global BIN spawn_id
    spawn $BIN $role --port $port --dir $dir {*}$args
    return $spawn_id
}

proc cmd  {id line} { send -i $id "$line\r" }

# Block until RE appears on ID (synchronization point, no assertion).
proc sync {id re} {
    expect {
        -i $id -re $re {}
        timeout { puts "  (timeout waiting for /$re/ )" }
        eof     { puts "  (eof waiting for /$re/ )" }
    }
}

# Assert RE appears on ID within the current timeout.
proc want {id re okmsg badmsg} {
    expect {
        -i $id -re $re { ok $okmsg }
        timeout        { bad $badmsg }
        eof            { bad "$badmsg (eof)" }
    }
}

proc shutdown {id} { catch { cmd $id quit }; catch { close -i $id }; catch { wait -i $id } }

# ---------------------------------------------------------------------------
puts "== Scenario A: late join AFTER a snapshot gets the full pre-snapshot state =="
set P [launch primary 9151 "$BASE/a-pr/" --reset]
sync $P "serving replicas on"
cmd $P "say A"; sync $P "committed #"
cmd $P "say B"; sync $P "committed #"
cmd $P "snapshot"; sync $P "snapshotted"
cmd $P "say C"; sync $P "committed #"
# only NOW does the standby connect -- after the snapshot rotated the log
set S [launch standby 9151 "$BASE/a-sb/"]
sync $S {in sync \(bootstrap}
cmd $S "list"
want $S {#\d+  A[\r\n]} "pre/post-snapshot message A replicated" "missing A after snapshot bootstrap"
want $S {#\d+  B[\r\n]} "pre/post-snapshot message B replicated" "missing B after snapshot bootstrap"
want $S {#\d+  C[\r\n]} "pre/post-snapshot message C replicated" "missing C after snapshot bootstrap"
shutdown $S; shutdown $P

# ---------------------------------------------------------------------------
puts "== Scenario B: reconnect RESUMES the objects missed during primary downtime =="
set S  [launch standby 9152 "$BASE/b-sb/" --follow]
set P1 [launch primary 9152 "$BASE/b-pr/" --reset]
sync $P1 "serving replicas on"
sync $S {in sync \(bootstrap}
cmd $P1 "say one"; sync $P1 "committed #"
cmd $P1 "say two"; sync $P1 "committed #"
sync $S {latest: two}
cmd $P1 "quit"
sync $S {primary disconnected}
# Downtime window: restart the primary (persistent, same epoch) and commit
# three/four before the standby's next reconnect, so they arrive via RESUME
# (silently) rather than as live events.
set P2 [launch primary 9152 "$BASE/b-pr/"]
sync $P2 "serving replicas on"
cmd $P2 "say three"; sync $P2 "committed #"
cmd $P2 "say four";  sync $P2 "committed #"
expect {
    -i $S -re {in sync \(resume} { ok "replica resumed (not full re-bootstrap)" }
    timeout { bad "expected a resume on reconnect" }
}
if {[string match {*latest: three*} $expect_out(buffer)]} {
    bad "missed object 'three' shown as LIVE (should be silent catch-up)"
} else {
    ok "missed object applied silently, not as a live event"
}
cmd $S "list"
want $S {#\d+  one[\r\n]}   "final state has one"   "final state missing one"
want $S {#\d+  two[\r\n]}   "final state has two"   "final state missing two"
want $S {#\d+  three[\r\n]} "final state has three" "final state missing three"
want $S {#\d+  four[\r\n]}  "final state has four"  "final state missing four"
shutdown $S; shutdown $P2

# ---------------------------------------------------------------------------
puts "== Scenario C: a RESET primary (new epoch) makes the replica re-bootstrap =="
set S  [launch standby 9153 "$BASE/c-sb/" --follow]
set P1 [launch primary 9153 "$BASE/c-pr/" --reset]
sync $P1 "serving replicas on"
sync $S {in sync \(bootstrap}
cmd $P1 "say old1"; sync $P1 "committed #"
cmd $P1 "say old2"; sync $P1 "committed #"
sync $S {latest: old2}
cmd $P1 "quit"
sync $S {primary disconnected}
# A RESET restart => new epoch + fresh data; the replica must re-bootstrap.
set P2 [launch primary 9153 "$BASE/c-pr/" --reset]
sync $P2 "serving replicas on"
cmd $P2 "say fresh"; sync $P2 "committed #"
want $S {in sync \(bootstrap} "re-bootstrapped on epoch change" "expected a second bootstrap"
cmd $S "list"
expect {
    -i $S -re {#\d+  fresh} { ok "replica mirrors the new primary's data" }
    timeout { bad "missing new primary data 'fresh'" }
}
if {[string match {*old1*} $expect_out(buffer)]} {
    bad "stale data 'old1' still in final state"
} else {
    ok "stale data dropped after epoch change"
}
shutdown $S; shutdown $P2

# ---------------------------------------------------------------------------
puts "== Scenario D: two replicas are served concurrently (fan-out) =="
set P  [launch primary 9154 "$BASE/d-pr/" --reset]
sync $P "serving replicas on"
set S1 [launch standby 9154 "$BASE/d-s1/"]
set S2 [launch standby 9154 "$BASE/d-s2/"]
sync $S1 {in sync \(bootstrap}
sync $S2 {in sync \(bootstrap}
cmd $P "say multi"; sync $P "committed #"
want $S1 {latest: multi} "replica 1 received the fan-out message" "replica 1 missed it"
want $S2 {latest: multi} "replica 2 received the fan-out message" "replica 2 missed it"
shutdown $S1; shutdown $S2; shutdown $P

# ---------------------------------------------------------------------------
puts "== Scenario E: the replica REPL outlives the primary, data retained =="
set S [launch standby 9155 "$BASE/e-sb/"]
set P [launch primary 9155 "$BASE/e-pr/" --reset]
sync $P "serving replicas on"
sync $S {in sync \(bootstrap}
cmd $P "say durable"; sync $P "committed #"
sync $S {latest: durable}
cmd $P "quit"
want $S {primary disconnected} "replica noticed the primary died" "no disconnect notice"
# the list runs after the primary died, and must still show the data
cmd $S "list"
want $S {#\d+  durable} "data still queryable after primary death" "data lost after primary death"
shutdown $S; catch { close -i $P }; catch { wait -i $P }

# ---------------------------------------------------------------------------
puts "== Scenario F: consistency under a burst of commits (writer queue / fan-out) =="
set S [launch standby 9156 "$BASE/f-sb/" --follow]
set P [launch primary 9156 "$BASE/f-pr/" --reset]
sync $P "serving replicas on"
sync $S {in sync \(bootstrap}
for {set i 1} {$i <= 40} {incr i} { cmd $P "say msg-$i" }
# the 40th apply on the standby prints "...|  40 message(s)  |..."
want $S {40 message\(s\)} "replica applied all 40 burst commits" "replica lost commits under burst"
shutdown $S; shutdown $P

# ---------------------------------------------------------------------------
puts "== Scenario G: shared-secret auth gates replication =="
# G1: matching secret -> replica receives data
set S [launch standby 9157 "$BASE/g-sb/" --secret s3cret]
set P [launch primary 9157 "$BASE/g-pr/" --reset --secret s3cret]
sync $P "serving replicas on"
sync $S {in sync \(bootstrap}
cmd $P "say authed"; sync $P "committed #"
want $S {latest: authed} "authenticated replica received data" "auth blocked a valid replica"
shutdown $S; shutdown $P
# G2: no secret on the replica -> rejected by a secret-protected primary
set S [launch standby 9158 "$BASE/g-sb2/"]
set P [launch primary 9158 "$BASE/g-pr2/" --reset --secret s3cret]
sync $P "serving replicas on"
cmd $P "say secret-data"; sync $P "committed #"
set timeout 6
expect {
    -i $S -re {secret-data|in sync \(} { bad "unauthenticated replica received data!" }
    timeout { ok "unauthenticated replica rejected, no data leaked" }
    eof     { ok "unauthenticated replica rejected, no data leaked" }
}
set timeout 30
shutdown $S; shutdown $P

# ---------------------------------------------------------------------------
puts "== Scenario H: replication over TLS (+ auth) =="
if {[catch { exec sh -c "command -v openssl" }]} {
    puts "  SKIP: openssl not available"
} else {
    exec openssl req -x509 -newkey rsa:2048 -keyout "$BASE/key.pem" -out "$BASE/cert.pem" \
        -days 1 -nodes -subj "/CN=primary" 2>/dev/null
    set S [launch standby 9159 "$BASE/h-sb/" --secret s3cret --tls]
    set P [launch primary 9159 "$BASE/h-pr/" --reset --secret s3cret \
               --tls-cert "$BASE/cert.pem" --tls-key "$BASE/key.pem"]
    sync $P "serving replicas on"
    sync $S {in sync \(bootstrap}
    cmd $P "say over-tls"; sync $P "committed #"
    want $S {latest: over-tls} "replication works over TLS + auth" "TLS replication failed"
    shutdown $S; shutdown $P
}

# ---------------------------------------------------------------------------
catch { exec rm -rf $BASE }
puts ""
puts "integration: $::PASS passed, $::FAIL failed"
exit [expr {$::FAIL == 0 ? 0 : 1}]
